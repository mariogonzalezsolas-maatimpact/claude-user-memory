        "error_log": [],
    }

    # Run workflow
    config = {"configurable": {"thread_id": "demo-1"}}
    print("=" * 60)
    print("Agentic Substrate v6.0 - LangGraph Core Workflow")
    print("=" * 60)

    result = graph.invoke(initial, config)

    print("\n" + "=" * 60)
