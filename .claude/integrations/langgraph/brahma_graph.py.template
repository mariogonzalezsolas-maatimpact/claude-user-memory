def implement_node(state: AgenticState) -> dict:
    """
    Tier 2: code-implementer (Opus 4.6)
    Executes plan with TDD: RED -> GREEN -> REFACTOR.
    Self-corrects up to 3 times before circuit breaker opens.
    """
    print(f"  [code-implementer] Implementing with TDD (attempt {state['retry_count'] + 1}/{MAX_RETRIES})")

    # --- STUB: Replace with actual implementation logic ---
    test_results = {
        "passing": 12,
        "failing": 0,
        "coverage": 87.5,
        "duration_ms": 3400,
    }
    artifacts = state.get("artifacts", []) + ["src/service.py", "tests/test_service.py"]
    # --- END STUB ---

    return {
        "test_results": test_results,
        "artifacts": artifacts,
        "current_agent": "code-implementer",
        "messages": [{"role": "assistant", "content": f"Implementation complete. {test_results['passing']} tests passing."}],
    }


def retry_node(state: AgenticState) -> dict:
    """Increment retry counter for self-correction loop."""
    new_count = state["retry_count"] + 1
    print(f"  [circuit-breaker] Retry {new_count}/{MAX_RETRIES}")

    if new_count >= MAX_RETRIES:
        return {
            "retry_count": new_count,
            "circuit_breaker": "open",
            "current_phase": "failed",
            "error_log": state.get("error_log", []) + ["Circuit breaker opened after 3 retries"],
        }

    return {"retry_count": new_count}


def complete_node(state: AgenticState) -> dict:
    """Mark workflow as successfully completed."""
    print(f"  [complete] Workflow finished. {len(state.get('artifacts', []))} files modified.")
    return {
        "current_phase": "complete",
        "messages": [{"role": "assistant", "content": "Workflow completed successfully."}],
    }


# =============================================================================
# ROUTING FUNCTIONS (quality gates as conditional edges)
# =============================================================================

def route_after_research(state: AgenticState) -> Literal["plan", "research"]:
    """Quality gate: Research score >= 80."""
    pack = state.get("research_pack")
    if pack and pack.get("score", 0) >= RESEARCH_THRESHOLD:
        return "plan"
    if state["retry_count"] >= MAX_RETRIES:
        return "plan"  # Will be caught by circuit breaker
    return "research"


def route_after_plan(state: AgenticState) -> Literal["analyze", "plan"]:
    """Quality gate: Plan score >= 85."""
    plan = state.get("implementation_plan")
    if plan and plan.get("score", 0) >= PLAN_THRESHOLD:
        return "analyze"
    if state["retry_count"] >= MAX_RETRIES:
        return "analyze"
    return "plan"


def route_after_analysis(state: AgenticState) -> Literal["implement", "plan"]:
    """Quality gate: Analysis score >= 80, no conflicts."""
    analysis = state.get("analysis_results")
    if analysis:
        score_ok = analysis.get("score", 0) >= ANALYSIS_THRESHOLD
        no_conflicts = len(analysis.get("conflicts", [])) == 0
        if score_ok and no_conflicts:
            return "implement"
    return "plan"  # Go back to planning if analysis fails


def route_after_implement(state: AgenticState) -> Literal["complete", "retry"]:
    """Quality gate: All tests passing."""
    tests = state.get("test_results")
    if tests and tests.get("failing", 1) == 0 and tests.get("passing", 0) > 0:
        return "complete"
    return "retry"


def route_after_retry(state: AgenticState) -> Literal["implement", "complete"]:
    """Circuit breaker check after retry."""
    if state.get("circuit_breaker") == "open":
        return "complete"  # Exit with failure status
    return "implement"


# =============================================================================
# BUILD GRAPH
# =============================================================================

def build_core_workflow(checkpointer=None) -> StateGraph:
    """
    Build the core Agentic Substrate workflow graph.

    Flow:
        START -> research -> [gate >= 80] -> plan -> [gate >= 85]
              -> analyze -> [gate >= 80] -> implement -> [tests pass]
              -> complete -> END

    With retry loops and circuit breaker protection at each gate.
    """
    builder = StateGraph(AgenticState)

    # Add nodes (one per agent)
    builder.add_node("research", research_node)
    builder.add_node("plan", plan_node)
    builder.add_node("analyze", analyze_node)
    builder.add_node("implement", implement_node)
    builder.add_node("retry", retry_node)
    builder.add_node("complete", complete_node)

    # Entry point
    builder.add_edge(START, "research")

    # Quality gate edges
    builder.add_conditional_edges("research", route_after_research,
                                  {"plan": "plan", "research": "retry"})
    builder.add_conditional_edges("plan", route_after_plan,
                                  {"analyze": "analyze", "plan": "retry"})
    builder.add_conditional_edges("analyze", route_after_analysis,
                                  {"implement": "implement", "plan": "plan"})
    builder.add_conditional_edges("implement", route_after_implement,
                                  {"complete": "complete", "retry": "retry"})

    # Retry loop
    builder.add_conditional_edges("retry", route_after_retry,
                                  {"implement": "implement", "complete": "complete"})

    # Exit
    builder.add_edge("complete", END)

    # Compile with optional checkpointer
    if checkpointer:
        return builder.compile(checkpointer=checkpointer)
    return builder.compile()


# =============================================================================
# USAGE
# =============================================================================

if __name__ == "__main__":
    # Build with in-memory checkpointer (use PostgresSaver for production)
    memory = InMemorySaver()
    graph = build_core_workflow(checkpointer=memory)

    # Create initial state
    initial = {
