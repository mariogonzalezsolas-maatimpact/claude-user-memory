"""
Agentic Substrate v6.0 - LangGraph State Definition

Unified state for the 15-agent, 4-tier workflow system.
Maps directly to the Agentic Substrate quality gates and circuit breaker.

USAGE:
    cp brahma_state.py.template brahma_state.py
    # Then import in brahma_graph.py

REQUIRES:
    pip install langgraph>=0.6.0 langchain-anthropic

Updated: 2026-02-24 | Agentic Substrate v6.0.0
"""

from typing import TypedDict, Annotated, Literal, Optional
from langgraph.graph import add_messages


# =============================================================================
# QUALITY GATE THRESHOLDS
# =============================================================================

RESEARCH_THRESHOLD = 80
PLAN_THRESHOLD = 85
ANALYSIS_THRESHOLD = 80
MAX_RETRIES = 3


# =============================================================================
# CORE STATE
# =============================================================================

class AgenticState(TypedDict):
    """
    Unified state for all Agentic Substrate workflows.

    Maps to 4 tiers:
      Tier 1 - Orchestration: chief-architect
      Tier 2 - Core: research -> plan -> analyze -> implement -> debug
      Tier 3 - Production: deploy -> monitor -> optimize
      Tier 4 - Growth: seo, business, content, product, security, ux
    """

    # --- Core ---
    messages: Annotated[list, add_messages]
    task_description: str
    current_phase: Literal[
        "research", "plan", "analyze", "implement",
        "deploy", "monitor", "optimize",
        "complete", "failed"
    ]
    active_tier: Literal["orchestration", "core", "production", "growth"]

    # --- Quality Gates (artifacts + scores) ---
    research_pack: Optional[dict]
    """ResearchPack from docs-researcher. Gate: score >= 80."""

    implementation_plan: Optional[dict]
    """Plan from implementation-planner. Gate: score >= 85."""

    analysis_results: Optional[dict]
    """Analysis from brahma-analyzer. Gate: score >= 80, no conflicts."""

    test_results: Optional[dict]
    """Tests from code-implementer. Gate: failing == 0."""

    # --- Circuit Breaker ---
    circuit_breaker: Literal["closed", "open"]
    retry_count: int

    # --- Execution ---
    artifacts: list[str]
    """File paths created/modified during implementation."""

    current_agent: Optional[str]
    """Active agent name (e.g. 'docs-researcher', 'code-implementer')."""

    error_log: list[str]
    """Errors encountered during workflow for debugging."""


# =============================================================================
# DEPLOYMENT STATE (extends core for Tier 3)
# =============================================================================

class DeploymentState(TypedDict):
    """Extended state for brahma-deployer canary workflows."""

    messages: Annotated[list, add_messages]
    task_description: str
    current_phase: Literal["pre_deploy", "canary_5", "canary_25", "canary_50", "canary_100", "monitoring", "complete", "rolled_back"]

    deployment_strategy: Literal["canary", "blue_green", "rolling"]
    canary_percentage: int
    health_metrics: Optional[dict]
    """{"error_rate": float, "latency_p99": int, "success_rate": float}"""

    rollback_triggered: bool
    artifacts: list[str]


# =============================================================================
# GROWTH STATE (extends core for Tier 4)
# =============================================================================

class GrowthAuditState(TypedDict):
    """State for parallel Growth tier audits (SEO + Security + UX + Business)."""

    messages: Annotated[list, add_messages]
    task_description: str

    seo_score: Optional[int]
    security_score: Optional[int]
    ux_score: Optional[int]
    business_score: Optional[int]

    seo_findings: Optional[dict]
    security_findings: Optional[dict]
    ux_findings: Optional[dict]
    business_findings: Optional[dict]

    combined_report: Optional[str]


# =============================================================================
# HELPERS
# =============================================================================

def create_initial_state(task: str, tier: str = "core") -> AgenticState:
    """Create initial state for a new workflow."""
    return {
        "messages": [],
        "task_description": task,
        "current_phase": "research",
        "active_tier": tier,
        "research_pack": None,
        "implementation_plan": None,
        "analysis_results": None,
        "test_results": None,
        "circuit_breaker": "closed",
        "retry_count": 0,
        "artifacts": [],
        "current_agent": None,
        "error_log": [],
    }


def check_quality_gate(state: AgenticState) -> dict:
    """
    Check if current phase passes its quality gate.

    Returns:
        {"passed": bool, "score": int|None, "threshold": int, "reason": str}
    """
    phase = state["current_phase"]

    if phase == "research":
        pack = state.get("research_pack")
        score = pack["score"] if pack else 0
        passed = score >= RESEARCH_THRESHOLD
        return {"passed": passed, "score": score, "threshold": RESEARCH_THRESHOLD,
                "reason": "" if passed else f"Research score {score} < {RESEARCH_THRESHOLD}"}

    if phase == "plan":
        plan = state.get("implementation_plan")
        score = plan["score"] if plan else 0
        passed = score >= PLAN_THRESHOLD
        return {"passed": passed, "score": score, "threshold": PLAN_THRESHOLD,
                "reason": "" if passed else f"Plan score {score} < {PLAN_THRESHOLD}"}

    if phase == "analyze":
        analysis = state.get("analysis_results")
        score = analysis["score"] if analysis else 0
        conflicts = analysis.get("conflicts", []) if analysis else []
        passed = score >= ANALYSIS_THRESHOLD and len(conflicts) == 0
        reason = ""
        if score < ANALYSIS_THRESHOLD:
            reason = f"Analysis score {score} < {ANALYSIS_THRESHOLD}"
        elif conflicts:
            reason = f"{len(conflicts)} unresolved conflicts"
        return {"passed": passed, "score": score, "threshold": ANALYSIS_THRESHOLD, "reason": reason}

    if phase == "implement":
        tests = state.get("test_results")
        if not tests:
            return {"passed": False, "score": None, "threshold": 0, "reason": "No test results"}
        passed = tests.get("failing", 1) == 0 and tests.get("passing", 0) > 0
        return {"passed": passed, "score": tests.get("passing", 0), "threshold": 0,
                "reason": "" if passed else f"{tests.get('failing', 0)} tests failing"}

    return {"passed": True, "score": None, "threshold": 0, "reason": ""}


def check_circuit_breaker(state: AgenticState) -> AgenticState:
    """Update circuit breaker based on retry count."""
    if state["retry_count"] >= MAX_RETRIES and state["circuit_breaker"] == "closed":
        return {**state, "circuit_breaker": "open", "current_phase": "failed"}
    return state


# =============================================================================
# USAGE
# =============================================================================

if __name__ == "__main__":
    state = create_initial_state("Add Redis caching to ProductService")
    gate = check_quality_gate(state)
    print(f"Phase: {state['current_phase']}")
    print(f"Gate: passed={gate['passed']}, score={gate['score']}, threshold={gate['threshold']}")
    print(f"Circuit breaker: {state['circuit_breaker']}")
